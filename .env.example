# =============================================================
# Variáveis de ambiente para docker-compose.app.yml
# Copie este arquivo para .env e preencha com os valores reais.
# =============================================================

# URL do Keycloak acessível pelo NAVEGADOR do usuário (não pelo container).
# Exemplo local:       http://localhost:8081
# Exemplo em rede:     http://192.168.1.34:8081
VITE_KEYCLOAK_URL=http://SEU_IP:8081

VITE_KEYCLOAK_REALM=portal-academico
VITE_KEYCLOAK_CLIENT_ID=portal-frontend

# Não é usada no bundle (api.ts usa /api relativo), mas pode ficar para referência.
VITE_API_URL=http://SEU_IP:3000
