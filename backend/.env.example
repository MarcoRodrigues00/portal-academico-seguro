PORT=3000
NODE_ENV=production
CORS_ORIGIN=http://IP_DA_VM_34

# true quando o backend fica atrás de um reverse proxy (nginx no .50)
# que adiciona X-Forwarded-For — necessário para rate limit por IP correto
TRUST_PROXY=false

# Em Docker: use host.docker.internal para alcançar o PostgreSQL no host
DATABASE_URL=postgresql://app_user:senha@host.docker.internal:5432/portal_academico

# Keycloak
# KEYCLOAK_URL é o fallback usado para derivar ISSUER e JWKS_URI quando os
# overrides abaixo não estão definidos. Em desenvolvimento local sem container
# basta definir só esta variável.
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=portal-academico
KEYCLOAK_CLIENT_ID=portal-backend

# --- Overrides para ambiente containerizado na VM da faculdade ---
# Problema: o navegador acessa Keycloak em localhost:8081 → tokens têm
#   iss = http://localhost:8081/realms/portal-academico
# Mas o backend em container não enxerga localhost:8081 e precisa usar
#   host.docker.internal:8081 para buscar a chave pública (JWKS).
# Solução: separar o issuer esperado (deve bater com o `iss` do token)
# da URI de busca de chave pública.
#
# Descomente e ajuste as duas linhas abaixo no .env da VM:
# KEYCLOAK_ISSUER=http://localhost:8081/realms/portal-academico
# KEYCLOAK_JWKS_URI=http://host.docker.internal:8081/realms/portal-academico/protocol/openid-connect/certs
